{
  "name": "@one-resume/docx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ATS-friendly DOCX generator for parsed CVs / projects. Renders @one-resume/domain data to .docx bytes via the `docx` npm package.",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@one-resume/domain": "*",
    "docx": "^9.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "test": "node --import tsx --test \"test/**/*.test.ts\""
  }
}
