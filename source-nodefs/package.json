{
  "name": "source-nodefs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node filesystem SourceResolver for core-parser: FileSystemSource (read/write/copy/list) + pipeline path config + the debug parse CLI.",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "core-parse": "bin/cli.ts"
  },
  "dependencies": {
    "core-parser": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
