# one-resume API — environment. Copy to `apps/api/.env` (loaded by the `api`
# script) or inject these in your host. The API reads markdown from a GitHub
# repo and serves parsed content JSON.

# GitHub source (the content repo octokit reads).
GITHUB_PAT=        # required — Personal Access Token with read access to the repo
GITHUB_OWNER=      # required — repo owner (user or org)
GITHUB_ROOT=       # required — repo name
GITHUB_REF=        # optional — branch / tag / sha (default branch if unset)

# Auth: every route except /health requires `X-API-KEY` matching this value.
API_KEY=           # required — shared secret, must be longer than 16 characters

# Listen port.
# PORT=3000        # optional — default 3000

# Typst binary for the /v1/pdf render endpoint. The Docker image bakes a pinned
# typst at this path; unset locally to resolve `typst` on PATH. If typst is
# unreachable, /v1/pdf returns 503 (the other routes are unaffected).
# TYPST_BIN=/usr/local/bin/typst
