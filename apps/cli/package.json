{
  "name": "one-resume-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The one-resume command-line app: parse | pdf | docx. Owns config, paths, and fs I/O; orchestrates the @one-resume/* libraries.",
