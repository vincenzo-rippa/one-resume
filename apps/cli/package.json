  },
  "dependencies": {
    "@one-resume/domain": "*",
    "@one-resume/parser": "*",
    "@one-resume/pdf": "*",
    "@one-resume/docx": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.22.2",
    "typescript": "^5.7.0"
  }
}