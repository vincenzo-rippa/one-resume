    "@one-resume/pdf": "*",
    "@one-resume/docx": "*",
    "@one-resume/content": "*",
    "@one-resume/localization": "*",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.22.2",
    "typescript": "^5.7.0"
  }
}