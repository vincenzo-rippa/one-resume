# one-resume CLI — optional overrides. Copy to `.env` (in this directory) to use.
#
# EVERY var is OPTIONAL. With none set, the CLI runs against the bundled CC0
# `examples/` and writes to `./out`, so a fresh clone produces real artifacts
# with zero configuration. Values may be absolute or relative to your shell's
# working directory.

# Markdown sources. cv/, projects/, and freelance/ live directly under this dir.
# Default: examples   (the bundled demo content)
# CONTENT_DIR=

# Base dir for all generated output (pdf/, ats/, and the public/ + locales/
# below when those are unset).
# Default: out
# OUTPUT_DIR=

# Where `pdf --public` writes the 4 site PDFs (en.pdf, it.pdf, projects.pdf,
# progetti.pdf).
# Default: <OUTPUT_DIR>/public
# SITE_PUBLIC_CV_DIR=

# Where `sync` writes the per-language content.json (en/content.json, ...).
# Default: <OUTPUT_DIR>/locales
# SITE_LOCALES_DIR=

# The typst binary the PDF renderer shells out to.
# Default: typst  (typst.exe on Windows) — resolved on PATH.
# TYPST_BIN=
