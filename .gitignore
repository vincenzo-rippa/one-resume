# dependencies
node_modules/

# generated build output (PDFs / DOCX / content.json — regenerated from source)
/out/

# Claude private data
.claude/

# typst temp cache
**/.cache/

# env: local overrides only — .env.example is committed
.env
.env.*.local

# private apps (e.g. a personal photo-CV variant) are vendored locally under
# apps/ but are never part of this repo — only cli and api belong here
apps/*
!apps/cli/
!apps/api/

# misc
.DS_Store
*.tsbuildinfo
.rest